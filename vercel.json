{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w @spr26/web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "functions": {
    "apps/web/app/api/transcribe/route.ts": { "maxDuration": 60 },
    "apps/web/app/api/embed/route.ts": { "maxDuration": 60 },
    "apps/web/app/api/qa/route.ts": { "maxDuration": 60 }
  }
}
