# Supabase — browser realtime + auth use these.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Postgres connection for Drizzle (api/transcribe, api/embed,
# future RAG). Use Supabase's **transaction pooler** (port 6543) for
# serverless. Format: postgres://postgres.<ref>:<pwd>@aws-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# LLM providers — set at least one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Groq — Whisper-large-v3 transcription via OpenAI-compatible API.
GROQ_API_KEY=
