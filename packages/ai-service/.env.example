# LLM provider keys. Used only when QA_MOCK=0 (see below). The QA endpoint
# uses ANTHROPIC_API_KEY if set (claude-opus-4-7), otherwise OPENAI_API_KEY
# (gpt-5.5).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# When set to anything other than "0", /api/qa returns a canned mock answer
# instead of calling the model. This is the default while we build out the
# UI; flip to QA_MOCK=0 once you have a key configured above.
QA_MOCK=1
