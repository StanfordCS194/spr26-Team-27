# LLM provider keys. The QA endpoint uses ANTHROPIC_API_KEY if set
# (claude-opus-4-7), otherwise OPENAI_API_KEY (gpt-5.5). Set at least one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embeddings (gemini-embedding-001 truncated to 1536d via Matryoshka).
# Required for transcript ingest, materials upload, and the QA retrieval path.
GOOGLE_GENERATIVE_AI_API_KEY=
