# LLM provider keys. The QA endpoint prefers OPENAI_API_KEY (gpt-4o-mini),
# falling back to ANTHROPIC_API_KEY (claude-opus-4-7) if only that is set.
# Copy this file to .env and fill in a key — once a key is present the
# endpoint stops mocking automatically.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Force the mock on/off. Leave unset to auto-pick: mock when no key is
# configured, real model when a key is present. Set QA_MOCK=1 to keep the
# canned answer even with a key (useful for UI work without burning credits).
QA_MOCK=
